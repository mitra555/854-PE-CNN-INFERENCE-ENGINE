# =============================================================================
# mmmc.tcl — Multi-Mode Multi-Corner (MMMC) Setup
# Design:    CNN_Inference_Engine (throughput-optimised)
# Tool:      Cadence Innovus
# Kit:       Cadence 45 nm generic cell library
#
# Corner strategy (industry standard):
#   SETUP  → slow cells + worst-case RC parasitics (Cmax)
#             Slow process, high temperature, low voltage → longest delays
#             → catches setup violations (data arrives too late)
#   HOLD   → fast cells + best-case RC parasitics (Cmin)
#             Fast process, low temperature, high voltage → shortest delays
#             → catches hold violations (data arrives too early)
#
# RC corner files: generated by Quantus/QRC extraction.
#   Cmax = worst-case (maximum coupling/resistance) → used for setup
#   Cmin = best-case  (minimum coupling/resistance) → used for hold
# =============================================================================

set PDK_ROOT /home/ms2025019_vaishnavi/cadence/pdks/cadence_45nm
set SDC_FILE /home/ms2025019_vaishnavi/cnn_ie_pd/constraints/cnn_ie_constraints.sdc


# -----------------------------------------------------------------------------
# 1. Timing library sets
# -----------------------------------------------------------------------------
# Slow library  — worst-case process/voltage/temperature (PVT)
create_library_set -name SLOW_LIB \
    -timing { ${PDK_ROOT}/lib/slow_vdd1v0_basicCells.lib }

# Fast library  — best-case PVT
create_library_set -name FAST_LIB \
    -timing { ${PDK_ROOT}/lib/fast_vdd1v0_basicCells.lib }


# -----------------------------------------------------------------------------
# 2. RC (parasitic) corners
#    QRC tech file must be present in the PDK.
#    Cmax → maximum parasitics → pessimistic delays → use for SETUP
#    Cmin → minimum parasitics → optimistic delays  → use for HOLD
# -----------------------------------------------------------------------------
create_rc_corner -name RC_WORST \
    -qrc_tech ${PDK_ROOT}/qrc/qrcTechFile \
    -T 125

create_rc_corner -name RC_BEST \
    -qrc_tech ${PDK_ROOT}/qrc/qrcTechFile \
    -T 0


# -----------------------------------------------------------------------------
# 3. Delay corners
#    Setup corner: slow cells + worst-case RC (Cmax) → maximum path delay
#    Hold  corner: fast cells + best-case  RC (Cmin) → minimum path delay
# -----------------------------------------------------------------------------
create_delay_corner -name DELAY_SETUP \
    -library_set SLOW_LIB \
    -rc_corner   RC_WORST

create_delay_corner -name DELAY_HOLD \
    -library_set FAST_LIB \
    -rc_corner   RC_BEST


# -----------------------------------------------------------------------------
# 4. Constraint mode  (single SDC shared across both views)
# -----------------------------------------------------------------------------
create_constraint_mode -name CONSTRAINTS \
    -sdc_files { ${SDC_FILE} }


# -----------------------------------------------------------------------------
# 5. Analysis views
# -----------------------------------------------------------------------------
create_analysis_view -name VIEW_SETUP \
    -delay_corner   DELAY_SETUP \
    -constraint_mode CONSTRAINTS

create_analysis_view -name VIEW_HOLD \
    -delay_corner   DELAY_HOLD \
    -constraint_mode CONSTRAINTS


# -----------------------------------------------------------------------------
# 6. Activate views
#    Setup check  → VIEW_SETUP  (slow corner)
#    Hold  check  → VIEW_HOLD   (fast corner)
# -----------------------------------------------------------------------------
set_analysis_view -setup { VIEW_SETUP } \
                  -hold  { VIEW_HOLD  }
